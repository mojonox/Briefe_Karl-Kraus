<?xml-model href="https://www.tei-c.org/release/xml/tei/custom/schema/relaxng/tei_all.rng" type="application/xml" schematypens="http://relaxng.org/ns/structure/1.0"?>
<TEI xmlns="http://www.tei-c.org/ns/1.0">
   <teiHeader>
      <fileDesc>
         <titleStmt>
            <title>Ortsregister</title>
         </titleStmt>
         <publicationStmt>
            <p>Zentrales Register der in der Edition genannten Orte.</p>
         </publicationStmt>
         <sourceDesc>
            <p>Erstellt aus den edierten Briefen und Postkarten an Karl Kraus.</p>
         </sourceDesc>
      </fileDesc>
   </teiHeader>
   <text>
      <body>
         <listPlace>
            <place xml:id="abbazia">
               <placeName>Abbazia</placeName>
               <placeName xml:lang="hr">Opatija</placeName>
               <note>Kurort an der kroatischen Adriaküste (heute Opatija); Absendeort der Postkarte von 1911.</note>
            </place>
            <place xml:id="wien">
               <placeName>Wien</placeName>
               <note>Wohnort von Karl Kraus; Empfangsort der Korrespondenz.</note>
            </place>
            <place xml:id="agram">
               <placeName>Agram</placeName>
               <placeName xml:lang="hr">Zagreb</placeName>
               <note>Absendeort des Briefs von 1901 (deutscher Name Agram, heute Zagreb, Kroatien).</note>
            </place>
            <place xml:id="bosnien">
               <placeName>Bosnien</placeName>
               <note>Im Brieftext genannt als Reiseziel, von dem die Absenderin zurückgekehrt ist.</note>
            </place>
            <place xml:id="st_margherita">
               <placeName>St. Margherita</placeName>
               <note>Im Brieftext genannter Ort (vermutlich Santa Margherita Ligure, Italien).</note>
            </place>
            <place xml:id="venedig">
               <placeName>Venedig</placeName>
               <placeName xml:lang="it">Venezia</placeName>
            </place>
            <place xml:id="genua">
               <placeName>Genua</placeName>
               <placeName xml:lang="it">Genova</placeName>
            </place>
            <place xml:id="ragusa">
               <placeName>Ragusa</placeName>
               <placeName xml:lang="hr">Dubrovnik</placeName>
               <note>Absendeort der Ansichtskarte von 1906 (deutscher/italienischer Name Ragusa, heute Dubrovnik, Kroatien). Auf dem gedruckten Kartentitel "Dubrovnik. — Ragusa." und im Poststempel.</note>
            </place>
            <place xml:id="ploce">
               <placeName>Ploče</placeName>
               <note>Handschriftlich auf der Bildseite der Ansichtskarte von 1906 notiert ("Ploče 94"); Ort an der dalmatinischen Küste (heute Kroatien).</note>
            </place>
         </listPlace>
      </body>
   </text>
</TEI>
