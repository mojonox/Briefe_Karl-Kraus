<?xml-model href="https://www.tei-c.org/release/xml/tei/custom/schema/relaxng/tei_all.rng" type="application/xml" schematypens="http://relaxng.org/ns/structure/1.0"?>
<TEI xmlns="http://www.tei-c.org/ns/1.0">
   <teiHeader>
      <fileDesc>
         <titleStmt>
            <title>Personenregister</title>
         </titleStmt>
         <publicationStmt>
            <p>Personenregister zur Edition der Korrespondenz an Karl Kraus.</p>
         </publicationStmt>
         <sourceDesc>
            <p>Aus den Editionsdateien abgeleitete Liste der erwähnten Personen.</p>
         </sourceDesc>
      </fileDesc>
   </teiHeader>
   <text>
      <body>
         <listPerson>
            <person xml:id="karl_kraus">
               <persName>
                  <forename>Karl</forename>
                  <surname>Kraus</surname>
               </persName>
               <birth><date when="1874-04-28">28. April 1874</date></birth>
               <death><date when="1936-06-12">12. Juni 1936</date></death>
               <note>Empfänger der Korrespondenz; österreichischer Schriftsteller, Satiriker und Herausgeber der Zeitschrift "Die Fackel".</note>
            </person>
            <person xml:id="hermann_bahr">
               <persName>
                  <forename>Hermann</forename>
                  <surname>Bahr</surname>
               </persName>
               <birth><date when="1863-07-19">19. Juli 1863</date></birth>
               <death><date when="1934-01-15">15. Januar 1934</date></death>
               <note>Österreichischer Schriftsteller und Kritiker; im Brief von 1901 im Zusammenhang mit dem Prozess Bahr-Kraus erwähnt.</note>
            </person>
            <person xml:id="jule_stoeckl">
               <persName>
                  <forename>Jule</forename>
                  <surname>Stöckl</surname>
               </persName>
               <persName type="alt">Julchen</persName>
               <note>Absenderin der Ansichtskarte (1906) und des Briefes (1907).</note>
            </person>
            <person xml:id="cristofoletti">
               <persName>Cristofoletti</persName>
               <note>Im Brief von Jule Stöckl (1907) erwähnt; die Lesung des Namens ist unsicher (Cristosoletti?).</note>
            </person>
            <person xml:id="rk">
               <persName>R. K.</persName>
               <note>Absender:in der Postkarte aus Abbazia (1911); nur durch die Initialen "R. K." bezeichnet, Identität nicht ermittelt.</note>
            </person>
            <person xml:id="may_v_h">
               <persName>Cont. May v. H.</persName>
               <note>Absender:in des Briefes aus Agram (1901); nur durch Kürzel bezeichnet, Identität nicht ermittelt.</note>
            </person>
         </listPerson>
      </body>
   </text>
</TEI>
